{
  "name": "algotrader",
  "version": "1.0.0",
  "description": "Algorithmic trading system supporting backtesting, paper trading, and live execution.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "collect": "tsx src/data/collect.ts",
    "analyze": "tsx src/data/analyze.ts",
    "backtest": "tsx src/backtest/run.ts",
    "regenerate": "tsx src/backtest/regenerate.ts",
    "live": "tsx src/live/runner.ts",
    "live-service": "tsx src/live/service.ts",
    "gen-docs": "tsx src/tools/gen-strategy-docs.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "imports": {
    "#core/*": "./src/core/*",
    "#backtest/*": "./src/backtest/*",
    "#strategies/*": "./data/shared/strategies/*",
    "#data/*": "./src/data/*",
    "#brokers/*": "./src/brokers/*"
  },
  "dependencies": {
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
