{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "#core/*": ["src/core/*"],
      "#backtest/*": ["src/backtest/*"],
      "#strategies/*": ["data/shared/strategies/*"],
      "#data/*": ["src/data/*"],
      "#brokers/*": ["src/brokers/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
